{
  "name": "better-react-media-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "ultracite check",
    "test": "turbo run test",
    "ci": "turbo run ci",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=better-react-media && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.5.4",
    "ultracite": "7.8.3",
    "vite": "^8.0.10"
  },
  "packageManager": "bun@1.3.13"
}
